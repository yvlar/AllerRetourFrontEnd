# ─── URL de l'API backend (CoRoute JAX-RS) ───────────────────────────
# En développement local (Vite proxy) : laisser /api  → proxifié vers :8080
# En production Docker : laisser /api → nginx rewrite vers api:8080
VITE_API_URL=/api

# ─── MongoDB (utilisé par docker-compose) ────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password
MONGO_DB=coroute

# ─── JWT secret (backend) ────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-prod
